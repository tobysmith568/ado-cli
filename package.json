{
  "name": "ado",
  "version": "0.0.0",
  "description": "A CLI for opening Azure DevOps pages for the current repository",
  "packageManager": "bun@1.3.6",
  "type": "module",
  "bin": {
    "ado": "./dist/ado"
  },
  "scripts": {
    "build": "bun build --compile src/cli/main.ts --outfile dist/ado",
    "build:js": "bun build src/cli/main.ts --outdir dist --target bun",
    "dev": "bun src/cli/main.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "bun test",
    "test:coverage": "bun test --coverage"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "azure-devops-node-api": "^15.1.2",
    "commander": "^14.0.3",
    "ini": "^6.0.0",
    "ink": "^6.8.0",
    "open": "^11.0.0",
    "react": "^19.2.4",
    "react-devtools-core": "^7.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "^1.3.10",
    "@types/ini": "^4.1.1",
    "@types/react": "^19.2.14",
    "mock-extended": "^0.1.0",
    "typescript": "^5.9.3"
  }
}
